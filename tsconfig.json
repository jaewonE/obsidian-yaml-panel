{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"lib": ["DOM", "ES5", "ES6", "ES7"]
	},
	"jsx": "react", // Or "preserve" if you plan to use JSX differently
	"jsxFactory": "h",
	"jsxFragmentFactory": "Fragment",
	"include": ["**/*.ts"]
}
